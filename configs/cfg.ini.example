; Скопируйте этот файл в configs/cfg.ini и подставьте свои значения.
; Файл configs/cfg.ini ДОЛЖЕН быть в .gitignore и НИКОГДА не должен попадать в репозиторий.

; Ключ, которым auth_key шифруется в таблице app_settings.
; При смене этого значения зашифрованная запись будет переcоздана автоматически.
; Сгенерируйте, например, командой: openssl rand -base64 64
db_encryption_key = "CHANGE_ME_TO_A_LONG_RANDOM_STRING"

; auth_key, который клиент обязан присылать в запросах login/register/admin.
; При смене все текущие сборки клиента перестанут проходить аутентификацию.
; Любая длинная случайная строка - пользователь вводит её в поле
; "Ключ шифрования логина и пароля".
client_auth_key = "CHANGE_ME_TO_A_LONG_RANDOM_STRING"

; Клиентская константа для шифрования мастер-ключа в localStorage (функция "запомнить ключ").
; При смене у пользователей "забудутся" уже сохранённые мастер-ключи.
; Сгенерируйте, например, командой: openssl rand -base64 64
local_storage_secret = "CHANGE_ME_TO_A_LONG_RANDOM_STRING"

; Учётные данные для первого admin'а. Используются один раз, при создании пустой БД.
; ОБЯЗАТЕЛЬНО смените пароль сразу после первого входа.
default_admin_login = "admin"
default_admin_password = "CHANGE_ME_AFTER_FIRST_LOGIN"
